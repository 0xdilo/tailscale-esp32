# Copy to .env and fill in values. Never commit .env.
WIFI_SSID=your-wifi-name
WIFI_PASS=your-wifi-password

# Device name shown in the Tailscale admin console and MagicDNS.
TAILSCALE_HOSTNAME=esp32-wake

# Generate with: openssl rand -hex 32
WAKE_TOKEN=replace-with-a-long-random-token

# This reduces scanner noise but is not a substitute for authentication.
# Generate the suffix with: openssl rand -hex 12
WAKE_PATH=/replace-with-a-random-path

# Wi-Fi MAC address of the computer to wake.
WAKE_MAC=00:11:22:33:44:55
